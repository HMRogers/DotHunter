      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.paperhallway.dothunter"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.paperhallway.dothunter",
      "versionCode": 2,
      "targetSdkVersion": 35,
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "391a274d-eb9c-4719-8ef4-91c5fc104c08"
      }
    },
    "owner": "poetunknown"
  }
}
